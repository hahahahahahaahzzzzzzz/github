# RepoLeak Watcher X - System Configurations

# Security
SECRET_KEY=your-secret-key-change-this-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Database Settings
# Default fallback to sqlite locally, PostgreSQL when running inside Docker
DATABASE_URL=sqlite:///./repoleak.db
# DATABASE_URL=postgresql://postgres:DBpassword123@localhost:5432/repoleak

# Queue Broker Settings
REDIS_URL=redis://localhost:6379/0

# GitHub Integration
# Comma-separated list of Personal Access Tokens for rate-limit rotation
GITHUB_TOKENS=

# Telegram Alert Configuration
# Set token and chat id to enable HTML notifications
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here
TELEGRAM_PERSONAL_CHAT_ID=your_personal_chat_id_here

# AI False Positive Assessment Engine
# API Key for Gemini 1.5 Flash evaluation
AI_API_KEY=

# Simulator Configurations
SIMULATION_MODE=true
SIMULATION_INTERVAL_SECONDS=8

# Auto-Scanner Daemon Settings
AUTO_SCAN_INTERVAL_SECONDS=600
SCAN_PUBLIC_REPOS=true
SCAN_PUBLIC_INTERVAL_SECONDS=15
